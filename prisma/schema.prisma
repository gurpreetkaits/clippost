generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String   @id @default(cuid())
  googleId        String   @unique
  email           String?
  name            String?
  image           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Billing
  polarCustomerId String?  @unique
  subscriptionId  String?  @unique
  plan            Plan     @default(FREE)
  planExpiresAt   DateTime?
  trialEndsAt     DateTime?  // 7-day Pro trial end date

  // Preferences
  autoPostInstagram Boolean @default(false)
  autoPostYoutube   Boolean @default(false)
  useAiCaptions     Boolean @default(true)

  // Defaults
  defaultLanguage String  @default("en-IN")
  defaultFormat   String  @default("original")
  defaultFrame    String  @default("cinema")
  autonomousMode  Boolean @default(false)

  // API access
  apiKey          String? @unique

  instagramAccounts  InstagramAccount[]
  youtubeChannels    YouTubeChannel[]
  videos             Video[]
  clips              Clip[]
  projects           Project[]
  usageRecords       UsageRecord[]
  billingEvents      BillingEvent[]
  captionTemplates   CaptionTemplate[]

  @@map("users")
}

enum Plan {
  FREE
  PRO
}

enum VideoSource {
  YOUTUBE
  UPLOAD
}

enum ProjectStatus {
  DRAFT
  RENDERING
  COMPLETE
}

model InstagramAccount {
  id                String   @id
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  username          String
  name              String
  profilePictureUrl String   @default("")
  accessToken       String
  tokenExpiresAt    DateTime
  facebookPageId    String
  isDefault         Boolean  @default(false)
  connectedAt       DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([userId, id])
  @@map("instagram_accounts")
}

model YouTubeChannel {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channelId     String
  channelTitle  String
  thumbnailUrl  String   @default("")
  accessToken   String
  refreshToken  String
  tokenExpiresAt DateTime
  isDefault     Boolean  @default(false)
  connectedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, channelId])
  @@map("youtube_channels")
}

model Video {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  youtubeId     String?
  title         String
  duration      Float
  filename      String
  sourceUrl     String?
  source        VideoSource @default(YOUTUBE)
  transcription Json?       // Stores CaptionSegment[] with timestamps
  language      String?     // Language used for transcription
  createdAt     DateTime    @default(now())
  clips         Clip[]
  projects      Project[]

  @@unique([userId, youtubeId])
  @@map("videos")
}

model Clip {
  id               String     @id @default(cuid())
  userId           String
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoId          String?
  video            Video?     @relation(fields: [videoId], references: [id], onDelete: SetNull)
  filename         String
  startTime        Float
  endTime          Float
  duration         Float
  hasCaptions      Boolean    @default(false)
  captionStyle     Json?
  method           ClipMethod @default(MANUAL)
  publishedAt      DateTime?
  instagramMediaId String?
  youtubeVideoId   String?
  createdAt        DateTime   @default(now())

  @@map("clips")
}

enum ClipMethod {
  MANUAL
  AUTO_TRIM
}

model UsageRecord {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    UsageAction
  metadata  Json?
  createdAt DateTime    @default(now())

  @@index([userId, action, createdAt])
  @@map("usage_records")
}

enum UsageAction {
  CLIP_CREATED
  VIDEO_DOWNLOADED
  PUBLISH
}

model CaptionTemplate {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  config    Json
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("caption_templates")
}

model BillingEvent {
  id              String   @id @default(cuid())
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  polarCustomerId String?
  eventType       String
  amount          Int?     // cents
  currency        String?
  status          String?
  subscriptionId  String?
  productId       String?
  metadata        Json?
  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
  @@map("billing_events")
}

model Project {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoId       String?
  video         Video?        @relation(fields: [videoId], references: [id], onDelete: SetNull)
  title         String        @default("Untitled Project")
  segments      Json?         // ProjectSegment[]
  captionStyle  Json?         // CaptionStyle
  layout        Json?         // VideoLayout
  textOverlays  Json?         // TextOverlay[]
  audioTracks   Json?         // AudioTrack[]
  filters       Json?         // FilterConfig
  status        ProjectStatus @default(DRAFT)
  outputFilename String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([userId, updatedAt])
  @@map("projects")
}
